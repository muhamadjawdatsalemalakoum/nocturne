{
  "name": "nocturne-monorepo",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/engine",
    "packages/server",
    "packages/ui",
    "packages/mcp",
    "packages/remote"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:ui": "npm --workspace @nocturne/ui run build",
    "build:mcp": "node scripts/build-mcp-bundle.mjs",
    "serve": "tsx packages/server/src/cli.ts",
    "e2e": "playwright test",
    "build:console": "npm --workspace @nocturne/ui run build:remote",
    "e2e:anywhere": "node scripts/anywhere-e2e.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
